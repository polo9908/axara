{
  "name": "@axaraaudit/runtime",
  "version": "0.1.4",
  "description": "Headless Playwright runtime (focus-trap detection) and Figma Variables connector",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "accessibility",
    "a11y",
    "playwright",
    "focus-trap",
    "figma",
    "design-tokens"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polo9908/axara.git",
    "directory": "packages/runtime"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@axaraaudit/core": "workspace:*",
    "playwright": "^1.48.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.4"
  }
}
