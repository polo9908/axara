{
  "name": "@a11yengine/runtime",
  "version": "0.0.0",
  "description": "Headless Playwright runtime (focus-trap detection) and Figma Variables connector",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@a11yengine/core": "workspace:*",
    "playwright": "^1.48.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.4"
  }
}
