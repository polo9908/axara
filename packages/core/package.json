{
  "name": "@a11yengine/core",
  "version": "0.0.0",
  "description": "Core logic: DTCG token parsing, static AST analysis & design-drift detection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.4"
  }
}
