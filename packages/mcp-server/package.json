{
  "name": "@axaraaudit/mcp-server",
  "version": "0.2.2",
  "description": "AxaraAudit MCP server: design-token rules, RGAA validation, project audit & drift auto-fix for AI agents (stdio, JSON-RPC 2.0)",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "accessibility",
    "a11y",
    "mcp",
    "model-context-protocol",
    "rgaa",
    "design-tokens"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polo9908/axara.git",
    "directory": "packages/mcp-server"
  },
  "bin": {
    "a11yengine-mcp": "./dist/index.js",
    "axaraaudit-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@axaraaudit/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.4"
  }
}
