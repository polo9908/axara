{
  "name": "@a11yengine/mcp-server",
  "version": "0.0.0",
  "description": "A11yEngine Model Context Protocol server (JSON-RPC 2.0 over stdio)",
  "type": "module",
  "bin": {
    "a11yengine-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@a11yengine/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.4"
  }
}
